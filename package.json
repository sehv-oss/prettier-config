{
  "name": "@sehv-oss/prettier-config",
  "version": "1.0.0",
  "description": "Prettier shared configuration for JavaScript/TypeScript projects",
  "type": "module",
  "main": ".prettier.config.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint:prettier": "prettier --config .prettier.config.ts --check .",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "files": [
    ".prettier.config.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "prettier",
    "prettier-config",
    "code-style"
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sehv-oss/prettier-config.git"
  },
  "peerDependencies": {
    "prettier": ">=3.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22 <27"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
